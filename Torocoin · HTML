<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TORO COIN — Geleceğin Dijital Ekosistemi</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
  :root {
    --navy-darkest: #020b18;
    --navy-deep: #040f1f;
    --navy-mid: #071529;
    --navy-light: #0a1f3d;
    --blue-dark: #0d3060;
    --blue-mid: #1458a8;
    --blue-bright: #1e78d4;
    --sky: #38b6ff;
    --sky-light: #7dd4ff;
    --sky-glow: #a8e4ff;
    --accent: #00d4ff;
    --accent-warm: #38cfff;
    --gold: #f0c040;
    --white: #f0f8ff;
    --text-muted: #6a9bc3;
    --text-dim: #3a6890;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background-color: var(--navy-darkest);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* ── NOISE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.4;
  }

  /* ── AMBIENT GLOW BLOBS ── */
  .blob {
    position: fixed;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
  }
  .blob-1 { width: 700px; height: 700px; background: radial-gradient(circle, rgba(20,88,168,0.18) 0%, transparent 70%); top: -200px; left: -200px; }
  .blob-2 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(56,182,255,0.12) 0%, transparent 70%); top: 40%; right: -150px; }
  .blob-3 { width: 400px; height: 400px; background: radial-gradient(circle, rgba(0,212,255,0.08) 0%, transparent 70%); bottom: 10%; left: 30%; }

  /* ── NAVBAR ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    padding: 0 6%;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(2,11,24,0.8);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(56,182,255,0.08);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .nav-logo-icon {
    width: 38px; height: 38px;
    background: linear-gradient(135deg, var(--blue-mid), var(--sky));
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    box-shadow: 0 0 20px rgba(56,182,255,0.35);
    position: relative;
    overflow: hidden;
  }
  .nav-logo-icon::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);
  }

  .nav-logo-text {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.3rem;
    letter-spacing: 0.06em;
    color: var(--white);
  }
  .nav-logo-text span { color: var(--sky); }

  .nav-links {
    display: flex;
    gap: 36px;
    list-style: none;
  }

  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    transition: color 0.25s;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0;
    width: 0; height: 1px;
    background: var(--sky);
    transition: width 0.25s;
  }
  .nav-links a:hover { color: var(--sky); }
  .nav-links a:hover::after { width: 100%; }

  .nav-cta {
    padding: 9px 24px;
    background: linear-gradient(135deg, var(--blue-mid), var(--blue-bright));
    border: 1px solid rgba(56,182,255,0.3);
    border-radius: 8px;
    color: var(--white) !important;
    font-weight: 500 !important;
    font-size: 0.85rem !important;
    transition: all 0.25s !important;
    box-shadow: 0 0 20px rgba(30,120,212,0.3);
  }
  .nav-cta:hover {
    box-shadow: 0 0 30px rgba(56,182,255,0.5) !important;
    transform: translateY(-1px);
  }

  /* ── SECTION BASE ── */
  section {
    position: relative;
    z-index: 1;
  }

  /* ── HERO ── */
  #hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 120px 6% 80px;
    overflow: hidden;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(56,182,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(56,182,255,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
  }

  .hero-content {
    max-width: 720px;
    animation: fadeUp 1s ease both;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(56,182,255,0.08);
    border: 1px solid rgba(56,182,255,0.2);
    border-radius: 100px;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sky);
    margin-bottom: 32px;
  }
  .hero-badge::before {
    content: '●';
    color: var(--accent);
    font-size: 0.6rem;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  h1 {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin-bottom: 28px;
  }

  h1 .line-accent {
    background: linear-gradient(90deg, var(--sky), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #8ab8d8;
    max-width: 560px;
    margin-bottom: 48px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    padding: 14px 32px;
    background: linear-gradient(135deg, var(--blue-mid), var(--sky));
    border: none;
    border-radius: 10px;
    color: white;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s;
    box-shadow: 0 0 40px rgba(56,182,255,0.3);
    letter-spacing: 0.02em;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 60px rgba(56,182,255,0.5);
  }

  .btn-outline {
    padding: 14px 32px;
    background: transparent;
    border: 1px solid rgba(56,182,255,0.25);
    border-radius: 10px;
    color: var(--sky-light);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 400;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s;
  }
  .btn-outline:hover {
    border-color: var(--sky);
    color: var(--sky);
    background: rgba(56,182,255,0.06);
  }

  .hero-visual {
    position: absolute;
    right: 4%;
    top: 50%;
    transform: translateY(-50%);
    width: 420px;
    height: 420px;
    pointer-events: none;
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(-50%) translateX(0); }
    50% { transform: translateY(calc(-50% - 20px)) translateX(-8px); }
  }

  .hero-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid;
    animation: spin linear infinite;
  }
  .ring-1 { inset: 0; border-color: rgba(56,182,255,0.15); animation-duration: 30s; }
  .ring-2 { inset: 40px; border-color: rgba(56,182,255,0.1); animation-duration: 20s; animation-direction: reverse; }
  .ring-3 { inset: 80px; border-color: rgba(56,182,255,0.08); animation-duration: 40s; }

  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

  .hero-center {
    position: absolute;
    inset: 120px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(20,88,168,0.4), rgba(2,11,24,0.8));
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 80px rgba(56,182,255,0.2), inset 0 0 40px rgba(56,182,255,0.1);
    font-size: 5rem;
  }

  .ring-dot {
    position: absolute;
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--sky);
    box-shadow: 0 0 12px var(--sky);
  }
  .ring-1 .ring-dot { top: 50%; left: -5px; transform: translateY(-50%); }
  .ring-2 .ring-dot { bottom: -5px; right: 50%; transform: translateX(50%); }

  /* ── STATS BAR ── */
  .stats-bar {
    padding: 40px 6%;
    background: rgba(7,21,41,0.6);
    border-top: 1px solid rgba(56,182,255,0.07);
    border-bottom: 1px solid rgba(56,182,255,0.07);
    display: flex;
    justify-content: center;
    gap: 0;
    flex-wrap: wrap;
  }

  .stat-item {
    padding: 12px 60px;
    text-align: center;
    border-right: 1px solid rgba(56,182,255,0.1);
  }
  .stat-item:last-child { border-right: none; }

  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 2.2rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--white), var(--sky));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* ── SECTION SHARED ── */
  .section-wrap {
    padding: 100px 6%;
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-tag {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sky);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-tag::before {
    content: '';
    width: 28px; height: 1px;
    background: var(--sky);
    display: inline-block;
  }

  h2 {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-bottom: 20px;
  }

  h2 .hl { color: var(--sky); }

  .section-lead {
    font-size: 1.05rem;
    line-height: 1.9;
    color: #7aa8c8;
    max-width: 620px;
    margin-bottom: 64px;
  }

  /* ── VIZYON / MISYON ── */
  #vizyon {
    background: linear-gradient(180deg, transparent, rgba(7,21,41,0.4) 50%, transparent);
  }

  .vm-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 48px;
  }

  .vm-card {
    padding: 48px 40px;
    background: rgba(7,21,41,0.7);
    border: 1px solid rgba(56,182,255,0.1);
    border-radius: 20px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
  }
  .vm-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--sky), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .vm-card:hover { border-color: rgba(56,182,255,0.25); transform: translateY(-4px); }
  .vm-card:hover::before { opacity: 1; }

  .vm-icon {
    width: 52px; height: 52px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(20,88,168,0.5), rgba(56,182,255,0.2));
    border: 1px solid rgba(56,182,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    margin-bottom: 24px;
  }

  .vm-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--sky-light);
  }

  .vm-text {
    font-size: 0.95rem;
    line-height: 1.85;
    color: #6a9bc3;
  }

  /* ── PROBLEM / ÇÖZÜM ── */
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .prob-card {
    padding: 32px 28px;
    background: rgba(4,15,31,0.8);
    border: 1px solid rgba(56,182,255,0.08);
    border-radius: 16px;
    transition: all 0.3s;
    position: relative;
  }
  .prob-card:hover {
    border-color: rgba(56,182,255,0.2);
    background: rgba(7,21,41,0.9);
    transform: translateY(-3px);
  }

  .prob-num {
    font-family: 'Syne', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: rgba(56,182,255,0.12);
    position: absolute;
    top: 20px; right: 24px;
    line-height: 1;
  }

  .prob-icon { font-size: 1.5rem; margin-bottom: 16px; }

  .prob-title {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--sky-light);
    margin-bottom: 10px;
    letter-spacing: 0.01em;
  }

  .prob-text {
    font-size: 0.875rem;
    line-height: 1.8;
    color: var(--text-muted);
  }

  /* ── ÇÖZÜM PILLARS ── */
  .solution-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
  }

  .sol-card {
    padding: 36px 28px;
    background: linear-gradient(135deg, rgba(20,88,168,0.12), rgba(7,21,41,0.8));
    border: 1px solid rgba(56,182,255,0.12);
    border-radius: 16px;
    text-align: center;
    transition: all 0.3s;
  }
  .sol-card:hover {
    border-color: rgba(56,182,255,0.3);
    box-shadow: 0 0 40px rgba(56,182,255,0.1);
    transform: translateY(-4px);
  }

  .sol-icon {
    width: 60px; height: 60px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(56,182,255,0.2), rgba(20,88,168,0.1));
    border: 1px solid rgba(56,182,255,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem;
    margin: 0 auto 20px;
    box-shadow: 0 0 20px rgba(56,182,255,0.15);
  }

  .sol-title {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 10px;
  }

  .sol-text {
    font-size: 0.85rem;
    line-height: 1.8;
    color: var(--text-muted);
  }

  /* ── UYGULAMA ── */
  #uygulama {
    background: linear-gradient(180deg, transparent, rgba(4,15,31,0.5) 50%, transparent);
  }

  .app-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .app-phone {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .phone-mockup {
    width: 240px;
    height: 480px;
    background: linear-gradient(145deg, rgba(10,31,61,0.95), rgba(2,11,24,0.99));
    border: 2px solid rgba(56,182,255,0.2);
    border-radius: 36px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    box-shadow:
      0 0 60px rgba(56,182,255,0.15),
      0 40px 80px rgba(0,0,0,0.5),
      inset 0 1px 0 rgba(255,255,255,0.05);
    position: relative;
    overflow: hidden;
    animation: float2 5s ease-in-out infinite;
  }

  @keyframes float2 {
    0%,100% { transform: translateY(0) rotate(-1deg); }
    50% { transform: translateY(-12px) rotate(1deg); }
  }

  .phone-mockup::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 80px; height: 24px;
    background: rgba(2,11,24,0.9);
    border-radius: 0 0 16px 16px;
    border-bottom: 1px solid rgba(56,182,255,0.1);
  }

  .phone-screen-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    padding: 40px 20px 20px;
    width: 100%;
  }

  .phone-bull {
    width: 64px; height: 64px;
    background: linear-gradient(135deg, var(--blue-mid), var(--sky));
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    box-shadow: 0 0 30px rgba(56,182,255,0.4);
  }

  .phone-app-name {
    font-family: 'Syne', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--white);
  }

  .phone-balance {
    text-align: center;
    padding: 16px 28px;
    background: rgba(56,182,255,0.08);
    border: 1px solid rgba(56,182,255,0.15);
    border-radius: 14px;
    width: calc(100% - 20px);
  }

  .phone-balance-label { font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; }
  .phone-balance-num { font-family: 'Syne', sans-serif; font-size: 1.5rem; font-weight: 700; color: var(--sky); margin-top: 4px; }

  .phone-mine-btn {
    width: calc(100% - 20px);
    padding: 14px;
    background: linear-gradient(135deg, var(--blue-mid), var(--sky));
    border: none;
    border-radius: 12px;
    color: white;
    font-family: 'Syne', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-align: center;
    box-shadow: 0 0 24px rgba(56,182,255,0.35);
    letter-spacing: 0.04em;
  }

  .phone-glow {
    position: absolute;
    width: 200px; height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(56,182,255,0.2), transparent 70%);
    bottom: -60px;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .app-features {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .feature-row {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 24px 28px;
    background: rgba(7,21,41,0.5);
    border: 1px solid rgba(56,182,255,0.08);
    border-radius: 14px;
    transition: all 0.3s;
  }
  .feature-row:hover {
    border-color: rgba(56,182,255,0.2);
    background: rgba(7,21,41,0.8);
  }

  .feature-icon-wrap {
    flex-shrink: 0;
    width: 44px; height: 44px;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(20,88,168,0.4), rgba(56,182,255,0.15));
    border: 1px solid rgba(56,182,255,0.15);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem;
  }

  .feature-info { flex: 1; }
  .feature-name {
    font-family: 'Syne', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--sky-light);
    margin-bottom: 4px;
  }
  .feature-desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.7; }

  /* ── TOKEN ── */
  #token {
    background: linear-gradient(135deg, rgba(4,15,31,0.6), transparent);
  }

  .token-layout {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 64px;
    align-items: start;
  }

  .token-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .token-coin {
    width: 180px; height: 180px;
    border-radius: 50%;
    background: linear-gradient(145deg, #1458a8, #0d3060, #071529);
    border: 3px solid rgba(56,182,255,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    font-size: 3.5rem;
    box-shadow:
      0 0 60px rgba(56,182,255,0.25),
      0 0 120px rgba(56,182,255,0.1),
      inset 0 1px 0 rgba(255,255,255,0.1);
    position: relative;
    animation: coinSpin 20s linear infinite;
  }

  @keyframes coinSpin {
    0%, 100% { box-shadow: 0 0 60px rgba(56,182,255,0.25), 0 0 120px rgba(56,182,255,0.1); }
